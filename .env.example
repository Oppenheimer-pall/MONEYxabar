# ════════════════════════════════════════
#  CARD BOT — Environment Variables
#  Bu faylni nusxa oling: cp .env.example .env
#  Keyin .env faylini to'ldiring
# ════════════════════════════════════════

# BotFather'dan olingan token (MAJBURIY)
BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin Telegram ID'lari (vergul bilan ajrating)
ADMIN_IDS=123456789,987654321

# Database yo'li (Railway'da /data/ bo'lishi shart)
DB_PATH=/data/card_bot.db

# Log darajasi (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# ── To'lov sozlamalari (ixtiyoriy) ──────
FEE_RATE_LOCAL=0.003
FEE_RATE_INTERNATIONAL=0.005
MIN_FEE_LOCAL=300
MAX_FEE_LOCAL=3000
MIN_FEE_INTERNATIONAL=500
MAX_FEE_INTERNATIONAL=5000
MIN_TRANSFER=1000
MAX_TRANSFER=50000000
MAX_DAILY_TRANSFER=100000000
